{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://futbolanaliz.local/sozlesmeler/mac-verisi.schema.json",
  "title": "Mac Verisi",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "iddaaEventId",
    "broadageId",
    "lig",
    "tarih",
    "saat",
    "evSahibi",
    "deplasman",
    "oranlar"
  ],
  "properties": {
    "iddaaEventId": {
      "type": "integer",
      "minimum": 1
    },
    "broadageId": {
      "type": "integer",
      "minimum": 0
    },
    "lig": {
      "type": "string",
      "minLength": 1
    },
    "tarih": {
      "type": "string",
      "format": "date"
    },
    "saat": {
      "type": "string",
      "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$"
    },
    "evSahibi": {
      "type": "string",
      "minLength": 1
    },
    "deplasman": {
      "type": "string",
      "minLength": 1
    },
    "oranlar": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/oran"
      }
    },
    "kaynak": {
      "type": "string",
      "default": "iddaa"
    },
    "veriGuveni": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    }
  },
  "$defs": {
    "oran": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bahisTuru",
        "deger"
      ],
      "properties": {
        "bahisTuru": {
          "type": "string",
          "enum": [
            "MAC_SONUCU_1",
            "MAC_SONUCU_X",
            "MAC_SONUCU_2",
            "CIFTE_SANS_1X",
            "CIFTE_SANS_X2",
            "ALT_2_5",
            "UST_2_5",
            "KARSILIKLI_GOL_VAR",
            "KARSILIKLI_GOL_YOK"
          ]
        },
        "deger": {
          "type": "number",
          "exclusiveMinimum": 1
        },
        "marketKodu": {
          "type": "integer"
        },
        "secim": {
          "type": "string"
        }
      }
    }
  }
}
